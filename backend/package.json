{
  "name": "fueleu-maritime-backend",
  "version": "1.0.0",
  "private": true,

  "engines": {
    "node": "18.x"
  },

  "scripts": {
    "dev": "ts-node-dev --respawn src/infrastructure/server/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/infrastructure/server/server.js",
    "postinstall": "prisma generate",

    "test": "jest --runInBand --forceExit",
    "test:unit": "jest domain.test --runInBand",
    "test:integration": "jest http.integration --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",

    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio"
  },

  "dependencies": {
    "@prisma/client": "^5.13.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },

  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
